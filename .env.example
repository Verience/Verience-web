# Google Tag Manager — also embedded in index.html (GTM-MWGZLGZ8)
# Optional override if you change containers without editing index.html
VITE_GTM_ID=GTM-MWGZLGZ8

# Optional: Meta Pixel ID — only used if you prefer direct load instead of GTM
# Leave empty when the pixel is managed inside GTM
VITE_META_PIXEL_ID=

# EmailJS (contact form)
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
